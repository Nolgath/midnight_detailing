# Copia este ficheiro para .env e ajusta os valores.
# Em desenvolvimento podes deixar tudo nos valores por defeito.

# --- Django ---
DJANGO_SECRET_KEY=substituir-em-producao
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- Email ---
# Dev: usa a consola (mostra os emails no terminal do runserver).
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend

# Produção: SMTP (exemplo com Gmail / Mailgun / etc.)
# DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.exemplo.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=user@exemplo.com
# EMAIL_HOST_PASSWORD=palavra-passe
# EMAIL_USE_TLS=True
# EMAIL_USE_SSL=False

DEFAULT_FROM_EMAIL=no-reply@midnightdetailing.pt
CONTACT_EMAIL=geral@midnightdetailing.pt

# --- Contactos do negócio ---
# Formato internacional (E.164) recomendado.
WHATSAPP_NUMBER=+351900000000
BUSINESS_PHONE=+351900000000

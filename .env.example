# Copia este ficheiro para .env e ajusta os valores.
# Em desenvolvimento podes deixar tudo nos valores por defeito.

# --- Django ---
DJANGO_SECRET_KEY=substituir-em-producao
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- Email ---
# Dev (sem enviar): mostra os emails no terminal do runserver.
# DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
#
# Produção / envio real via Gmail SMTP:
#   Cria uma App Password em https://myaccount.google.com/apppasswords
#   (requer verificação em 2 passos) e usa-a em EMAIL_HOST_PASSWORD.
DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_HOST_USER=mddetailing2026@gmail.com
EMAIL_HOST_PASSWORD=app-password-de-16-caracteres

DEFAULT_FROM_EMAIL=Midnight Detailing <mddetailing2026@gmail.com>
CONTACT_EMAIL=mddetailing2026@gmail.com

# Destino das marcações (carrinho -> "Marcar e concluir")
BOOKING_EMAIL=mddetailing2026@gmail.com

# --- Contactos do negócio ---
# Formato internacional (E.164) recomendado.
WHATSAPP_NUMBER=+351900000000
BUSINESS_PHONE=+351900000000

# --- SEO local / presença online ---
# URL pública do site (canonical, sitemap, Open Graph). No Render é detetado automaticamente.
# SITE_URL=https://midnightdetailing.pt
GOOGLE_BUSINESS_URL=https://share.google/WTt0SSLsVUKHG4ySR
# Os ícones na página Sobre só aparecem quando definidos.
INSTAGRAM_URL=https://www.instagram.com/midnight.detailing.oficial/
FACEBOOK_URL=
TIKTOK_URL=https://www.tiktok.com/@midnight.detailin8
# Nº de reviews na ficha Google (ex.: 12) — ativa o aggregateRating 5.0 no JSON-LD.
GOOGLE_REVIEW_COUNT=
